{
  "name": "@eventforge/api",
  "version": "0.1.0",
  "private": true,
  "description": "EventForge core REST API (NestJS 11 + Fastify).",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@eventforge/db": "workspace:*",
    "@eventforge/domain": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/swagger": "^11.0.2",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^5.1.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.1",
    "mjml": "^4.15.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^16.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eventforge/config": "workspace:*",
    "@nestjs/testing": "^11.0.1",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.4"
  }
}
