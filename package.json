{
  "name": "eventforge",
  "version": "0.1.0",
  "private": true,
  "description": "EventForge — a production-grade Zoho Backstage / Events clone (Next.js + NestJS + Supabase).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "env:sync": "node scripts/sync-env.js",
    "db:generate": "pnpm env:sync && pnpm --filter @eventforge/db db:generate",
    "db:migrate": "pnpm env:sync && pnpm --filter @eventforge/db db:migrate",
    "db:seed": "pnpm env:sync && pnpm --filter @eventforge/db db:seed",
    "sdk:gen": "pnpm --filter @eventforge/api-sdk gen",
    "prepare": "node scripts/sync-env.js && husky || true"
  },
  "devDependencies": {
    "@eventforge/config": "workspace:*",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.2.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
