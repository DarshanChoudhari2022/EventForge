{
  "version": 2,
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @eventforge/db db:generate && pnpm --filter web build",
  "outputDirectory": "apps/web/.next",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://eventforge-api.onrender.com/api/v1/:path*"
    }
  ]
}
