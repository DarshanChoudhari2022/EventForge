# ─────────────────────────────────────────────────────────────
# EventForge — environment template.
# Copy to `.env` (or `.env.local` per app) and fill in.
# NEVER commit real secrets. CI uses GitHub Actions secrets.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── Supabase (data plane: Postgres + Auth + Realtime + Storage) ──
# Project ref: gxwombxqyyhvzfjseixc
SUPABASE_URL=https://gxwombxqyyhvzfjseixc.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd4d29tYnhxeXlodnpmanNlaXhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNzEzNzAsImV4cCI6MjA5Nzk0NzM3MH0.EJZxPLO0fjQ7KwS0UqSKTws9_GIH6u42HUnNRmjQN7I
SUPABASE_SERVICE_ROLE_KEY=             # ⚠ REQUIRED: Project Settings → API → service_role. Server only.
SUPABASE_JWT_SECRET=                   # ⚠ REQUIRED: Project Settings → API → JWT Secret
SUPABASE_DB_PASSWORD=                  # ⚠ REQUIRED: Project Settings → Database password

# Connection strings. Pooler (port 6543) for app runtime; direct (5432) for migrations.
DATABASE_URL=postgresql://postgres.gxwombxqyyhvzfjseixc:CHANGE_ME@aws-0-pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_DATABASE_URL=postgresql://postgres.gxwombxqyyhvzfjseixc:CHANGE_ME@aws-0-pooler.supabase.com:5432/postgres

# ── Redis (Upstash) — BullMQ queues, rate limit, hot cache ──
REDIS_URL=rediss://default:password@your-upstash-host.upstash.io:6379

# ── Core API (NestJS) ──
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
JWT_ISSUER=eventforge
OPENAPI_PUBLIC_BASE_URL=http://localhost:4000

# ── Web (Next.js) ──
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://gxwombxqyyhvzfjseixc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd4d29tYnhxeXlodnpmanNlaXhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNzEzNzAsImV4cCI6MjA5Nzk0NzM3MH0.EJZxPLO0fjQ7KwS0UqSKTws9_GIH6u42HUnNRmjQN7I

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email (Resend primary, Postmark fallback) ──
RESEND_API_KEY=
EMAIL_FROM="EventForge <noreply@eventforge.app>"
EMAIL_PROVIDER=resend                 # resend | postmark
POSTMARK_API_KEY=

# ── Video / virtual sessions ──
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── Observability (OpenTelemetry → OTLP) ──
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=

# ── Misc ──
FEATURE_FLAGS_PROVIDER=               # unleash | launchdarkly
CONTACT_EMAIL=hello@eventforge.app
