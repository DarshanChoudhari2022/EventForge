{
  "name": "@eventforge/api-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "gen": "openapi-typescript ../../apps/api/openapi.json -o ./src/schema.ts",
    "clean": "rimraf node_modules dist .turbo"
  },
  "dependencies": {
    "@eventforge/domain": "workspace:*"
  },
  "devDependencies": {
    "@eventforge/config": "workspace:*",
    "openapi-typescript": "^7.4.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2"
  }
}
